#!/usr/bin/env bash
set -eo pipefail -u

while read -r name owner; do

  if [[ ${1:-} == "$name" ]]; then

    if [[ ${2:-} != '' ]]; then
      DIR=~/code/$2
    elif [[ $name =~ ^(apsis)(-)(.*)$ ]]; then
      DIR=~/code/apsis/${BASH_REMATCH[3]}
    else
      DIR=~/code/$name
    fi

    printf '\e[37m fetching \e[36m%s \e[37m· \e[35m<C-f> \e[37mcd\e[0m\n' "${DIR/#$HOME/\~}"

    if [[ -d $DIR ]]; then
      pushd "$DIR" >/dev/null
      git show-ref --quiet --verify refs/heads/main && BRANCH=main || BRANCH=master
      git checkout --quiet "$BRANCH" && git pull --prune --quiet
      popd >/dev/null
    else
      git clone --quiet "git@github.com:$owner/$name.git" "$DIR"
    fi

    echo "$DIR" >/tmp/fetch-dir # my-fetch-cd

  fi

done <"$XDG_CACHE_HOME/fetch/repos"
